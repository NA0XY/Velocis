# Runtime
NODE_ENV=development
PORT=3001
IS_LOCAL=true
LOG_LEVEL=info

# Frontend and CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# AWS core
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_ACCOUNT_ID=123456789012
DYNAMO_LOCAL_ENDPOINT=http://localhost:8000

# DynamoDB table names (typed config)
DYNAMO_REPOSITORIES_TABLE=velocis-repositories
DYNAMO_USERS_TABLE=velocis-main
DYNAMO_AI_ACTIVITY_TABLE=velocis-ai-activity
# Single-table override — DYNAMO_USERS_TABLE falls back to this when not set
DYNAMODB_TABLE_NAME=velocis-main

# Legacy table names still read by some handlers/scripts
USERS_TABLE=velocis-main
REPOS_TABLE=velocis-repos
ACTIVITY_TABLE=velocis-activity
SENTINEL_TABLE=velocis-sentinel
PIPELINE_TABLE=velocis-pipeline-runs
CORTEX_TABLE=velocis-cortex
TIMELINE_TABLE=velocis-timeline
DEPLOYS_TABLE=velocis-deployments
ANNOTATIONS_TABLE=velocis-annotations
CHAT_TABLE=velocis-workspace-chat
INSTALL_TABLE=velocis-installations
SCAN_JOBS_TABLE=velocis-scan-jobs
IAC_TABLE=velocis-iac
IAC_JOBS_TABLE=velocis-iac-jobs
HEALTH_TABLE=velocis-system-health

# Auth and encryption
JWT_SECRET=replace-with-a-strong-random-secret
TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# GitHub OAuth / App
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-secret
GITHUB_WEBHOOK_URL=http://localhost:3001/api/webhooks/github
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Bedrock and AI models
BEDROCK_REGION=us-east-1
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_LLAMA_MODEL_ID=meta.llama3-70b-instruct-v1:0
BEDROCK_TITAN_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.2

# Step Functions and API controls
STEP_FUNCTIONS_STATE_MACHINE_ARN=
API_GATEWAY_BASE_URL=
API_RATE_LIMIT_PER_MINUTE=60

# WebSocket
WEBSOCKET_API_ENDPOINT=
WEBSOCKET_ENDPOINT=
WEBSOCKET_CONNECTION_TABLE=velocis-ws-connections
CODEBASE_CONTEXT_TABLE=

# Translation and observability
TRANSLATE_ENABLED=true
TRANSLATE_DEFAULT_SOURCE_LANG=en
SENTRY_DSN=
POWERTOOLS_SERVICE_NAME=velocis-backend
POWERTOOLS_METRICS_NAMESPACE=Velocis

# Feature flags
FEATURE_MULTILINGUAL_MENTOR=true
FEATURE_IAC_PREDICTOR=true
FEATURE_CORTEX_3D=true
FEATURE_FORTRESS_TDD=true
FEATURE_VIBE_CODING=true
